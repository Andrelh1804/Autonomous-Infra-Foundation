modules = ["nodejs-20", "python-3.12", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AII Backend (FastAPI)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AII Frontend (Next.js)"

[[workflows.workflow]]
name = "AII Backend (FastAPI)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3.12 -m uvicorn backend.api.v1.app:app --host 0.0.0.0 --port 8008 --reload --reload-dir backend"
waitForPort = 8008

[[workflows.workflow]]
name = "AII Frontend (Next.js)"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/frontend && ./node_modules/.bin/next dev -p 5000"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8008
externalPort = 8008

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql"]

[userenv]

[userenv.shared]
SECRET_KEY = "aii-platform-secret-key-replit-2024-change-in-production"
